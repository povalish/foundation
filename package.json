{
  "name": "foundation",
  "scripts": {
    "prepare": "simple-git-hooks",
    "check:types": "tsc --noEmit",
    "check:lint": "eslint \"./**/*.ts{,x}\" --max-warnings=10",
    "check:lint:fix": "eslint \"./**/*.ts{,x}\" --fix",
    "check:test": "vitest --watch=false",
    "----X----": "",
    "code": "tsx ./src/main.ts",
    "test": "vitest --watch=true"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run check:lint && npm run check:types",
    "pre-push": "npm run test:watch"
  },
  "dependencies": {
    "@types/node": "^22.13.9",
    "eslint-config-prettier": "^10.0.2",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "3.5.3",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.26.0"
  }
}
